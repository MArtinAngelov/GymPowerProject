using System;
using System.IO;
using System.Text.RegularExpressions;
using Markdig;

namespace MSWordConverter
{
    class Program
    {
        static void Main(string[] args)
        {
            try
            {
                string basePath = @"C:\Users\1\source\repos\GymPowerProject\";
                string p1 = File.ReadAllText(basePath + "GymPower_Diploma.md");
                string p2 = File.ReadAllText(basePath + "GymPower_Diploma_Part2.md");
                
                string p3_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part3.md");
                string[] p3_parts = p3_raw.Split(new string[] { "---" }, StringSplitOptions.None);
                
                string p4_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part4.md");
                string[] p4_parts = p4_raw.Split(new string[] { "---" }, StringSplitOptions.None);
                
                string p5_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part5.md");
                string[] p5_parts = p5_raw.Split(new string[] { "---" }, StringSplitOptions.None);

                string p6_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part6.md");
                string[] p6_parts = p6_raw.Split(new string[] { "---" }, StringSplitOptions.None);

                string p7_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part7.md");
                string[] p7_parts = p7_raw.Split(new string[] { "---" }, StringSplitOptions.None);

                string p8_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part8.md");
                string[] p8_parts = p8_raw.Split(new string[] { "---" }, StringSplitOptions.None);

                string p9_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part9.md");
                string[] p9_parts = p9_raw.Split(new string[] { "---" }, StringSplitOptions.None);

                string p10_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part10.md");
                string p10 = p10_raw;

                string p11_raw = File.ReadAllText(basePath + "GymPower_Diploma_Part11.md");
                string[] p11_parts = p11_raw.Split(new string[] { "---" }, StringSplitOptions.None);

                string markdownBytes = 
                    p1 + "\n\n" + 
                    p2 + "\n\n" + 
                    p3_parts[0] + "\n\n" + 
                    p4_parts[0] + "\n\n" + 
                    p5_parts[0] + "\n\n" + 
                    p6_parts[0] + "\n\n" + 
                    p7_parts[0] + "\n\n" + 
                    p8_parts[0] + "\n\n" + 
                    p9_parts[0] + "\n\n" + 
                    p10 + "\n\n" + 
                    p11_parts[0] + "\n\n" + 
                    "---\n\n" + 
                    p3_parts[1] + "\n\n" + 
                    "---\n\n" + 
                    p3_parts[2] + "\n\n" + 
                    "---\n\n" + 
                    p3_parts[3] + "\n\n" + 
                    p4_parts[1] + "\n\n" + 
                    p5_parts[1] + "\n\n" + 
                    p6_parts[1] + "\n\n" + 
                    p7_parts[1] + "\n\n" + 
                    p8_parts[1] + "\n\n" + 
                    p9_parts[1] + "\n\n" +
                    p11_parts[1] + "\n\n";

                // Rename Headers based on user image schema
                markdownBytes = markdownBytes.Replace("УВОД (ВЪВЕДЕНИЕ)", "1. Увод");
                markdownBytes = markdownBytes.Replace("1. ОСНОВНА ЧАСТ", "2. Изложение");
                markdownBytes = markdownBytes.Replace("2. ЗАКЛЮЧЕНИЕ", "3. Заключение");
                markdownBytes = markdownBytes.Replace("3. СПИСЪК НА ИЗПОЛЗВАНАТА ЛИТЕРАТУРА", "4. Информационни източници");
                markdownBytes = markdownBytes.Replace("4. ПРИЛОЖЕНИЯ", "5. Приложения");

                // Shift all 1.x. subchapters to 2.x.
                markdownBytes = Regex.Replace(markdownBytes, @"(?m)^1\.(\d+)\.", "2.$1.");

                // Inject code blocks, tables, and graphs replacing the placeholders requested by the user
                markdownBytes = markdownBytes.Replace("(Тук можете да сложите Фигура 1: Архитектурна схема)", 
                    "```mermaid\n" +
                    "graph TD;\n" +
                    "  Browser-->Controller;\n" +
                    "  Controller-->Model;\n" +
                    "  Model-->Database;\n" +
                    "  Controller-->View;\n" +
                    "  View-->Browser;\n" +
                    "```\n<p class='caption'>Фигура 1: Архитектурен модел Model-View-Controller</p>");

                markdownBytes = markdownBytes.Replace("(Тук можете да сложите Фигура 3: Екранна снимка на началната страница на GymPower)", 
                    "<div style='text-align: center;'><img src='C:/Users/1/source/repos/GymPowerProject/wwwroot/images/hero/hero_1.jpg' style='max-width:100%; border: 1px solid black;' /></div>\n<p class='caption'>Фигура 3: Дизайн на началната страница</p>");

                markdownBytes = markdownBytes.Replace("(Тук можете да сложите Фигура 4: Процес на финализиране на поръчка / Количка)", 
                    "| Стъпка | Действие | Резултат |\n" +
                    "| --- | --- | --- |\n" +
                    "| 1 | Преглед на количка | Потвърждаване на продуктите |\n" +
                    "| 2 | Попълване на данни | Име, Имейл, Телефон, Адрес |\n" +
                    "| 3 | Плащане | Наложен платеж |\n" +
                    "| 4 | Запис в базата | Създаване на Order и OrderItems |\n\n" +
                    "<p class='caption'>Фигура 4: Процес на финализиране на поръчка</p>");

                markdownBytes = markdownBytes.Replace("(Тук можете да сложите Фигура 5: Екранна снимка на диалогов прозорец с AI Асистента)", 
                    "```csharp\n" +
                    "// Пример за комуникация с Google Gemini API\n" +
                    "var payload = new { contents = new[] { new { parts = new[] { new { text = userPrompt } } } } };\n" +
                    "var response = await _httpClient.PostAsync(url, content);\n" +
                    "```\n<p class='caption'>Фигура 5: Интеграция на AI Assistant</p>");

                markdownBytes = markdownBytes.Replace("(Тук можете да сложите Фигура 6: Пример за генериран автоматичен имейл при поръчка)", 
                    "```html\n" +
                    "<h1> GymPower Успешна Поръчка! </h1>\n" +
                    "<h2> Здравейте, Иван! </h2>\n" +
                    "<h3> Обща сума: €65.00 </h3>\n" +
                    "```\n<p class='caption'>Фигура 6: Автоматизиран HTML SMTP имейл</p>");
                
                string outputPath = basePath + "GymPower_Diploma_Thesis_Final_35Pages.doc";
                
                var pipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
                string htmlBody = Markdown.ToHtml(markdownBytes, pipeline);

                htmlBody = Markdown.ToHtml(markdownBytes, pipeline);

                // Strip the old markdown cover page AND old TOC completely.
                // We know the real text starts at "<h2>1. Увод</h2>"
                int startIndex = htmlBody.IndexOf("<h2>1. Увод</h2>");
                if (startIndex > 0)
                {
                    htmlBody = htmlBody.Substring(startIndex);
                }

                // Add nice centered headings (without page breaks!)
                htmlBody = htmlBody.Replace("<h2>1. Увод</h2>", "<h2 style='text-align:center;'>1. Увод</h2>");
                htmlBody = htmlBody.Replace("<h2>2. Изложение</h2>", "<h2 style='text-align:center;'>2. Изложение</h2>");
                htmlBody = htmlBody.Replace("<h2>3. Заключение</h2>", "<h2 style='text-align:center;'>3. Заключение</h2>");
                htmlBody = htmlBody.Replace("<h2>4. Информационни източници</h2>", "<h2 style='text-align:center;'>4. Информационни източници</h2>");
                htmlBody = htmlBody.Replace("<h2>5. Приложения</h2>", "<h2 style='text-align:center;'>5. Приложения</h2>");

                System.Text.StringBuilder tocBuilder = new System.Text.StringBuilder();
                tocBuilder.AppendLine("<br clear='all' style='page-break-before:always' />");
                tocBuilder.AppendLine("<h2 style='text-align:center; margin-bottom: 20pt;'>СЪДЪРЖАНИЕ</h2>");
                tocBuilder.AppendLine("<table style='width:100%; border:none; margin-bottom: 30pt; font-size:12pt;' cellpadding='0' cellspacing='0'>");
                tocBuilder.AppendLine("<tr><td style='border:none; text-indent:0; padding:2px; white-space: nowrap;'>1. Увод</td><td style='border:none; border-bottom: 1px dotted black; width: 100%;'></td><td style='border:none; width:30px; text-align:right;'>2</td></tr>");
                tocBuilder.AppendLine("<tr><td style='border:none; text-indent:0; padding:2px; white-space: nowrap;'>2. Изложение</td><td style='border:none; border-bottom: 1px dotted black; width: 100%;'></td><td style='border:none; width:30px; text-align:right;'>3</td></tr>");

                var matches = Regex.Matches(markdownBytes, @"(?m)^2\.(\d+)\.\s+(.*)$");
                foreach (Match m in matches)
                {
                    string num = m.Groups[1].Value;
                    string title = m.Groups[2].Value.Trim().Replace("\"", "&quot;");
                    int estimatedPage = 3 + (int)(int.Parse(num) * 0.85); // Approximate page placement
                    tocBuilder.AppendLine($"<tr><td style='border:none; text-indent:0; padding-left: 20px; padding-top: 2px; padding-bottom: 2px; white-space: nowrap;'>2.{num}. {title}</td><td style='border:none; border-bottom: 1px dotted black; width: 100%;'></td><td style='border:none; width:30px; text-align:right;'>{estimatedPage}</td></tr>");
                }

                tocBuilder.AppendLine("<tr><td style='border:none; text-indent:0; padding:2px; white-space: nowrap;'>3. Заключение</td><td style='border:none; border-bottom: 1px dotted black; width: 100%;'></td><td style='border:none; width:30px; text-align:right;'>32</td></tr>");
                tocBuilder.AppendLine("<tr><td style='border:none; text-indent:0; padding:2px; white-space: nowrap;'>4. Информационни източници</td><td style='border:none; border-bottom: 1px dotted black; width: 100%;'></td><td style='border:none; width:30px; text-align:right;'>33</td></tr>");
                tocBuilder.AppendLine("<tr><td style='border:none; text-indent:0; padding:2px; white-space: nowrap;'>5. Приложения</td><td style='border:none; border-bottom: 1px dotted black; width: 100%;'></td><td style='border:none; width:30px; text-align:right;'>34</td></tr>");
                tocBuilder.AppendLine("</table>");
                tocBuilder.AppendLine("<br clear='all' style='page-break-before:always' />");

                string tocHtml = tocBuilder.ToString();


                // Create the exact visual cover page from the user's image
                string customCoverPage = @"
<div class='cover-page'>
    <p style='margin-bottom: 80pt;'>
        <ins style='text-decoration:none;'>Професионална гимназия по електротехника и електроника</ins><br>
        <ins style='text-decoration:none;'>„Константин Фотинов“, гр. Бургас</ins>
    </p>

    <h1 style='text-align: center; font-size: 20pt; margin-bottom: 100pt;'>ДИПЛОМЕН ПРОЕКТ</h1>

    <div style='text-align: left; text-indent: 0;'>
        <p style='text-align: left; text-indent: 0;'>
            на.........Мартин Костадинов Ангелов.................... ученик от ХII .Б.клас<br><br>
            професия- код: „..481030..............“ - .....Приложен програмист........................<br><br>
            специалност- код: „.....4810301..........“ - Приложно програмиране................<br><br>
        </p>
    </div>

    <div style='text-align: left; text-indent: 0; margin-top: 50pt;'>
        <p style='text-align: left; text-indent: 0;'><b>Тема: Сайт за фитнес добавки и спортни продукти</b>....................................................................</p>
        <p style='text-align: left; text-indent: 0;'><b>Изисквания за разработката на дипломния проект:</b></p>
    </div>

    <div style='text-align: left; text-indent: 0; margin-top: 100pt;'>
        <p style='text-align: left; text-indent: 0;'>
            <b>Ръководител-консултант:</b>............................................................................................<br><br>
            Сесия: май-юни 2026г.<br><br>
            Дата:............................
        </p>
    </div>
</div>
";
                htmlBody = customCoverPage + tocHtml + htmlBody;

                outputPath = basePath + "GymPower_Diploma_Thesis_Final_v3.doc";

                // We inject mso page headers for Top Right corner pagination
                string fullHtml = $@"<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'>
<head>
    <meta charset='utf-8'>
    <style>
        /* Define the right-aligned page number footer */
        @page WordSection1 {{
            size: 595.3pt 841.9pt; /* A4 */
            margin: 70.85pt 56.7pt 70.85pt 85.05pt; /* ~2.5cm 2cm 2.5cm 3cm */
            mso-header-margin: 35.4pt;
            mso-footer-margin: 35.4pt;
            mso-footer: f1;
            mso-paper-source: 0;
        }}
        div.WordSection1 {{ page: WordSection1; }}
        body {{
            font-family: 'Times New Roman', serif;
            font-size: 12pt;
            line-height: 1.5; 
            text-align: justify;
        }}
        p {{
            text-indent: 1.25cm;
            margin-top: 0;
            margin-bottom: 10pt;
            text-align: justify;
        }}
        .cover-page p {{
            text-indent: 0;
            text-align: center;
            font-size: 12pt;
            margin-bottom: 0;
        }}
        h1, h2, h3, h4, h5, h6 {{ 
            font-weight: bold; 
            font-family: 'Times New Roman', serif; 
            text-align: left;
            margin-top: 15pt;
        }}
        pre {{ background: #f4f4f4; padding: 10px; border: 1px solid #ccc; font-family: Consolas, monospace; font-size: 10pt; text-indent: 0; }}
        table {{ border-collapse: collapse; width: 100%; margin-bottom: 15pt; border: 1px solid black; text-indent: 0; }}
        th, td {{ border: 1px solid black; padding: 5px; text-align: left; text-indent: 0; }}
        .caption {{ font-size: 11pt; font-style: italic; text-align: center; margin-top: 5px; margin-bottom: 20pt; text-indent: 0; }}
    </style>
</head>
<body>
    <div style='mso-element:footer' id=f1>
        <p class=MsoFooter style='text-align:right; text-indent:0; margin:0;'>
            <!-- This magical string injects the auto-updating Word Page Number in the bottom right -->
            <span style='mso-field-code:"" PAGE ""'></span>
        </p>
    </div>

    <div class='WordSection1'>
        {htmlBody}
    </div>
</body>
</html>";

                File.WriteAllText(outputPath, fullHtml);
                Console.WriteLine("Success! Official Word Document created.");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error: " + ex.Message);
            }
        }
    }
}
