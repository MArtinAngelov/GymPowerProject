@using Microsoft.AspNetCore.Http
@{
    var username = Context.Session.GetString("Username");
    var role = Context.Session.GetString("Role");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}
<!DOCTYPE html>
<html lang="bg" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymPower</title>
    <!-- Fonts & Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap & Custom CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <!-- ✅ Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand text-uppercase fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fas fa-dumbbell me-2"></i> GymPower
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Начало</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Products" asp-action="Index">Продукти</a>
                    </li>
                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning" asp-controller="Admin" asp-action="Index">Админ Панел</a>
                        </li>
                    }
                </ul>

                <!-- Theme Toggle -->
                <button class="btn btn-sm btn-outline-light me-3" id="themeToggle" title="Смени тема">
                    <i class="fas fa-moon"></i>
                </button>

                <!-- Search -->
                <form class="d-flex me-3 position-relative" asp-controller="Products" asp-action="Index" method="get">
                    <input class="form-control me-2 rounded-pill" type="search" name="search" id="searchInput" placeholder="Търси..." autocomplete="off">
                    <!-- Results Dropdown -->
                    <div id="searchResults" class="list-group position-absolute w-100 shadow-lg mt-1" style="top: 100%; display: none; z-index: 1000;"></div>
                </form>

                <!-- Auth & Cart -->
                <ul class="navbar-nav align-items-center">
                    @if (!string.IsNullOrEmpty(Context.Session.GetString("Username")))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 user-dropdown-toggle"
                               href="#" id="userDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="user-avatar-circle">@(Context.Session.GetString("Username")?[0].ToString().ToUpper())</span>
                                <span class="fw-semibold" data-bg="Здравей, @Context.Session.GetString("Username")" data-en="Hi, @Context.Session.GetString("Username")">Здравей, @Context.Session.GetString("Username")</span>
                                <i class="fas fa-chevron-down small opacity-75"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end user-dropdown-menu shadow-lg" aria-labelledby="userDropdown">
                                <!-- Language -->
                                <li class="px-3 pt-2 pb-1">
                                    <div class="d-flex align-items-center">
                                        <i class="fas fa-globe me-2 text-warning"></i>
                                        <span class="small text-muted me-auto" data-bg="Език" data-en="Language">Език</span>
                                        <div class="lang-toggle-group">
                                            <button class="lang-btn" id="langBtnBg" onclick="setLanguage('bg')" title="Български">БГ</button>
                                            <button class="lang-btn" id="langBtnEn" onclick="setLanguage('en')" title="English">EN</button>
                                        </div>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <!-- Edit Profile -->
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Account" asp-action="EditProfile">
                                        <i class="fas fa-user-edit text-warning"></i>
                                        <span data-bg="Редактирай профил" data-en="Edit Profile">Редактирай профил</span>
                                    </a>
                                </li>
                                <!-- Orders -->
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2" asp-controller="MyOrders" asp-action="Index">
                                        <i class="fas fa-box text-warning"></i>
                                        <span data-bg="Поръчки" data-en="My Orders">Поръчки</span>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <!-- Logout -->
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2 text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="fas fa-sign-out-alt"></i>
                                        <span data-bg="Изход" data-en="Logout">Изход</span>
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Вход</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Регистрация</a></li>
                    }
                    <li class="nav-item ms-2">
                        <a class="btn btn-warning rounded-pill px-3" asp-controller="Cart" asp-action="Index">
                            <i class="fa fa-shopping-cart"></i> <span id="cartCountBadge" class="badge bg-dark ms-1">0</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ✅ Main Content -->
    <main class="flex-grow-1 py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- ✅ Footer -->
    <footer class="text-center py-4">
        <div class="container">
            <div class="mb-3">
                <a href="#" class="text-white mx-2"><i class="fab fa-facebook fa-lg"></i></a>
                <a href="#" class="text-white mx-2"><i class="fab fa-instagram fa-lg"></i></a>
            </div>
            <p class="mb-0 text-white-50">&copy; 2024 GymPower. Всички права запазени.</p>
        </div>
    </footer>

    <!-- ✅ AI Chat Widget (Floating) -->
    <div id="aiChatButton" class="chat-widget-btn" title="AI Треньор">
        <i class="fas fa-robot"></i>
    </div>

    <div id="aiChatWindow" class="chat-window">
        <!-- Header -->
        <div class="chat-header">
            <span><i class="fas fa-dumbbell me-2"></i>GymPower AI</span>
            <button id="closeChat" class="btn btn-sm text-white"><i class="fas fa-times"></i></button>
        </div>
        <!-- Body -->
        <div id="chatMessages" class="chat-body">
            <div class="message ai">
                Здравей! Аз съм твоят виртуален треньор. С какво мога да ти помогна днес? 🏋️‍♂️
            </div>
        </div>
        <!-- Footer -->
        <div class="chat-footer">
            <div class="input-group">
                <input type="text" id="chatInput" class="form-control hover-shadow" placeholder="Попитай нещо..." style="border-radius: 20px 0 0 20px;">
                <button id="sendMessage" class="btn btn-primary" style="border-radius: 0 20px 20px 0;">
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        /* User Dropdown Styles */
        .user-dropdown-toggle {
            padding: 6px 12px;
            border-radius: 50px;
            transition: background 0.2s;
        }
        .user-dropdown-toggle:hover {
            background: rgba(255,255,255,0.08) !important;
        }
        .user-avatar-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f5a623, #e8650a);
            color: #fff;
            font-weight: 700;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .user-dropdown-menu {
            min-width: 220px;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px;
            padding: 8px 0;
            background: #1a1a2e;
            margin-top: 8px !important;
        }
        .user-dropdown-menu .dropdown-item {
            color: #e0e0e0;
            padding: 10px 16px;
            border-radius: 8px;
            margin: 2px 6px;
            transition: background 0.15s;
            font-size: 0.9rem;
        }
        .user-dropdown-menu .dropdown-item:hover {
            background: rgba(245,166,35,0.12);
            color: #fff;
        }
        .user-dropdown-menu .dropdown-item.text-danger:hover {
            background: rgba(220,53,69,0.12);
        }
        .user-dropdown-menu .dropdown-divider {
            border-color: rgba(255,255,255,0.08);
        }
        /* Language Toggle */
        .lang-toggle-group {
            display: flex;
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.15);
        }
        .lang-btn {
            background: transparent;
            border: none;
            color: rgba(255,255,255,0.5);
            padding: 3px 10px;
            font-size: 11px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            letter-spacing: 0.5px;
        }
        .lang-btn.active {
            background: #f5a623;
            color: #000;
        }
        .lang-btn:hover:not(.active) {
            color: #fff;
        }
    </style>
    <script>
        // 🌓 Theme Toggle
        const themeBtn = document.getElementById('themeToggle');
        const html = document.documentElement;
        
        themeBtn.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            themeBtn.innerHTML = next === 'dark' ? '<i class="fas fa-moon"></i>' : '<i class="fas fa-sun"></i>';
        });

        // Restore Theme
        const savedTheme = localStorage.getItem('theme') || 'dark';
        html.setAttribute('data-theme', savedTheme);
        themeBtn.innerHTML = savedTheme === 'dark' ? '<i class="fas fa-moon"></i>' : '<i class="fas fa-sun"></i>';

        // 🤖 Chat Widget Logic
        const chatBtn = document.getElementById('aiChatButton');
        const chatWin = document.getElementById('aiChatWindow');
        const closeChat = document.getElementById('closeChat');
        const chatInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('sendMessage');
        const messages = document.getElementById('chatMessages');

        // Open/Close
        chatBtn.addEventListener('click', () => {
            chatWin.style.display = 'flex';
            chatBtn.style.display = 'none'; // Optional: hide button when open
        });
        
        closeChat.addEventListener('click', () => {
            chatWin.style.display = 'none';
            chatBtn.style.display = 'flex';
        });

        // Send Message
        async function sendMessage() {
            const text = chatInput.value.trim();
            if(!text) return;

            // Add User Message
            appendMessage(text, 'user');
            chatInput.value = '';

            // Add Loading Bubble
            const loadingId = 'loading-' + Date.now();
            appendMessage('<i class="fas fa-ellipsis-h fa-fade"></i>', 'ai', loadingId);

            try {
                // Call API
                const response = await fetch('/Chat/SendMessage', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text })
                });

                if (!response.ok) {
                    const errText = await response.text();
                    throw new Error(errText || `Server Error ${response.status}`);
                }
                
                const data = await response.json();
                
                // Remove Loading & Add AI Response
                document.getElementById(loadingId).remove();
                appendMessage(data.response, 'ai');
            } catch (err) {
                console.error(err);
                document.getElementById(loadingId).remove();
                appendMessage('⚠️ Грешка: ' + err.message, 'ai');
            }
        }

        function appendMessage(text, role, id = null) {
            const div = document.createElement('div');
            div.className = `message ${role}`;
            if(id) div.id = id;
            div.innerHTML = text; // Allow HTML for icons
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
        }

        sendBtn.addEventListener('click', sendMessage);
        chatInput.addEventListener('keypress', (e) => {
            if(e.key === 'Enter') sendMessage();
        });

        // 🛒 Update Cart Count
        async function updateCartCount() {
            try {
                const res = await fetch('/Cart/GetCartCount');
                if(res.ok) {
                    const data = await res.json();
                    const badge = document.getElementById('cartCountBadge');
                    if(badge) {
                        badge.innerText = data.count;
                        badge.style.display = data.count > 0 ? 'inline-block' : 'none';
                    }
                }
            } catch(e) { console.error('Failed to load cart count', e); }
        }

        // Run on load
        document.addEventListener('DOMContentLoaded', () => {
             updateCartCount();
        });

        // 🔍 Autocomplete logic (Simplified)
        const searchIn = document.getElementById('searchInput');
        const searchRes = document.getElementById('searchResults');
        
        searchIn.addEventListener('input', async (e) => {
             const term = e.target.value;
             if(term.length < 2) { searchRes.style.display = 'none'; return; }
             
             const res = await fetch(`/api/products/search?term=${term}`);
             const data = await res.json();
             
             searchRes.innerHTML = '';
             if(data.length > 0) {
                 searchRes.style.display = 'block';
                 data.forEach(p => {
                     const a = document.createElement('a');
                     a.className = 'list-group-item list-group-item-action';
                     a.href = `/Products/Details/${p.id}`;
                     // Currency Conversion Display in JS (Simple approx)
                     const priceEur = (p.price / 1.95583).toFixed(2);
                     a.innerHTML = `<img src="${p.imageUrl}" width="30" class="me-2 rounded">${p.name} - <strong>${priceEur} €</strong>`;
                     searchRes.appendChild(a);
                 });
             } else {
                 searchRes.style.display = 'none';
             }
        });

        // Close search when clicking outside
        document.addEventListener('click', (e) => {
            if (!searchIn.contains(e.target) && !searchRes.contains(e.target)) {
                searchRes.style.display = 'none';
            }
        });
    </script>
    <script>
        // 🌐 Language Switcher
        function getCookie(name) {
            const v = document.cookie.match('(^|;) ?' + name + '=([^;]*)(;|$)');
            return v ? v[2] : null;
        }

        function setLanguage(lang) {
            document.cookie = 'lang=' + lang + ';path=/;max-age=31536000';
            applyLanguage(lang);
            updateLangButtons(lang);
        }

        function applyLanguage(lang) {
            document.querySelectorAll('[data-bg][data-en]').forEach(function(el) {
                el.textContent = lang === 'en' ? el.getAttribute('data-en') : el.getAttribute('data-bg');
            });
        }

        function updateLangButtons(lang) {
            var bgBtn = document.getElementById('langBtnBg');
            var enBtn = document.getElementById('langBtnEn');
            if (bgBtn && enBtn) {
                bgBtn.classList.toggle('active', lang === 'bg' || !lang);
                enBtn.classList.toggle('active', lang === 'en');
            }
        }

        var _currentLang = getCookie('lang') || 'bg';
        document.addEventListener('DOMContentLoaded', function() {
            applyLanguage(_currentLang);
            updateLangButtons(_currentLang);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
