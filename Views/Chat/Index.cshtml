@model List<GymPower.Models.ChatMessage>
@{
    ViewData["Title"] = "AI Асистент";
}

<style>
    .chat-container {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        height: 75vh;
        border: 1px solid rgba(255, 107, 53, 0.3);
        border-radius: 15px;
        background: rgba(26, 26, 46, 0.95);
        backdrop-filter: blur(10px);
        overflow: hidden;
        box-shadow: 0 0 20px rgba(0,0,0,0.5);
    }

    .chat-header {
        background: var(--gradient-dark);
        padding: 15px;
        border-bottom: 2px solid var(--primary);
        color: var(--light);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .chat-box {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        background-image: url('/images/gym-pattern-dark.png'); /* Optional texture */
        background-blend-mode: overlay;
    }

    .message {
        max-width: 80%;
        padding: 12px 18px;
        border-radius: 15px;
        font-size: 1rem;
        line-height: 1.5;
        position: relative;
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .message.user {
        align-self: flex-end;
        background: var(--primary);
        color: white;
        border-bottom-right-radius: 2px;
        box-shadow: 0 4px 15px rgba(255, 107, 53, 0.2);
    }

    .message.assistant {
        align-self: flex-start;
        background: #2a2a40; /* Slightly lighter than dark background */
        color: var(--light);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-bottom-left-radius: 2px;
    }

    .input-area {
        display: flex;
        padding: 20px;
        background: var(--darker);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        gap: 10px;
    }

    .input-area input {
        flex: 1;
        padding: 12px 20px;
        background: #1a1a2e;
        border: 1px solid #444;
        border-radius: 25px;
        color: white;
        outline: none;
        transition: border-color 0.3s;
    }

    .input-area input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 10px rgba(255, 107, 53, 0.2);
    }

    .input-area button {
        padding: 10px 25px;
        border: none;
        background: var(--gradient);
        color: white;
        border-radius: 25px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s transform;
    }

    .input-area button:hover {
        transform: scale(1.05);
        box-shadow: 0 0 15px rgba(255, 107, 53, 0.4);
    }

    .quick-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 10px 20px;
        background: rgba(0,0,0,0.2);
    }

    .quick-btn {
        background: transparent;
        border: 1px solid var(--primary);
        color: var(--light);
        padding: 6px 14px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.3s;
    }
    
    .quick-btn:hover {
        background: var(--primary);
        color: white;
    }

    .typing-indicator {
        display: none;
        padding: 10px 20px;
        font-style: italic;
        color: #aaa;
        font-size: 0.9rem;
    }
</style>

<div class="row justify-content-center">
    <div class="col-md-10">
        <h2 class="text-center my-4 fw-bold text-uppercase" style="letter-spacing: 2px;">
            <i class="fas fa-robot text-warning"></i> GymPower AI Assistant
        </h2>

        <div class="chat-container">
            <!-- Header for context -->
            <div class="chat-header">
                <div>
                    <h5 class="m-0 fw-bold">Асистент за добавки</h5>
                    <small class="text-white-50">Онлайн</small>
                </div>
            </div>

            <div class="chat-box" id="chatBox">
                <!-- Welcome Message if empty -->
                @if (Model == null || !Model.Any())
                {
                    <div class="message assistant">
                        Здравей! Аз съм твоят GymPower AI треньор. 💪<br /> 
                        Мога да ти помогна с избор на добавки, тренировъчни съвети и възстановяване. Попитай ме нещо!
                    </div>
                }
                else
                {
                    foreach (var msg in Model)
                    {
                        <div class="message @(msg.Role.ToLower())">
                            @msg.Message
                        </div>
                    }
                }
            </div>

            <div class="typing-indicator" id="typingIndicator">
                <i class="fas fa-circle-notch fa-spin"></i> GymPower AI мисли...
            </div>

            <div class="quick-buttons">
                <button class="quick-btn" onclick="setPrompt('Препоръчай ми протеин за мускулна маса')">🥤 Протеин за маса</button>
                <button class="quick-btn" onclick="setPrompt('Какви добавки за отслабване имате?')">🔥 Отслабване</button>
                <button class="quick-btn" onclick="setPrompt('Имам нужда от енергия преди тренировка')">⚡ Енергия</button>
                <button class="quick-btn" onclick="setPrompt('Как да възстановявам по-бързо?')">🛌 Възстановяване</button>
            </div>

            <div class="input-area">
                <input type="text" id="userMessage" placeholder="Напишете съобщение..." onkeypress="handleKeyPress(event)" />
                <button onclick="sendMessage()"><i class="fas fa-paper-plane"></i></button>
            </div>
        </div>
    </div>
</div>

<script>
    const chatBox = document.getElementById("chatBox");
    const userMessageInput = document.getElementById("userMessage");
    const typingIndicator = document.getElementById("typingIndicator");

    // Scroll to bottom on load
    chatBox.scrollTop = chatBox.scrollHeight;

    function setPrompt(text) {
        userMessageInput.value = text;
        sendMessage();
    }

    function handleKeyPress(e) {
        if (e.key === "Enter") {
            sendMessage();
        }
    }

    async function sendMessage() {
        const text = userMessageInput.value.trim();
        if (!text) return;

        // Add User Message UI
        addMessage(text, 'user');
        userMessageInput.value = '';
        typingIndicator.style.display = 'block';

        try {
            const response = await fetch('/Chat/SendMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            });

            if (response.ok) {
                const data = await response.json();
                addMessage(data.response, 'assistant');
            } else {
                addMessage("Възникна грешка. Моля, опитайте отново.", 'assistant');
            }
        } catch (error) {
            console.error("Chat error:", error);
            addMessage("Грешка при свързване.", 'assistant');
        } finally {
            typingIndicator.style.display = 'none';
        }
    }

    function addMessage(text, role) {
        const div = document.createElement("div");
        div.className = `message ${role}`;
        div.textContent = text;
        chatBox.appendChild(div);
        chatBox.scrollTop = chatBox.scrollHeight;
    }
</script>
