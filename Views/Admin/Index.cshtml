@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Админ Панел";
    var username = Context.Session.GetString("Username");
}

<section class="hero-section text-center text-white py-5" style="background: var(--gradient-dark);">
    <div class="container">
        <h1 class="hero-title fw-bold mb-3 text-warning">⚙️ Админ Панел</h1>
        <p class="lead text-light">
            Добре дошъл, <strong>@username</strong>! Управлявай съдържанието на своя онлайн магазин GymPower.
        </p>
    </div>
</section>

<div class="container py-5 text-white">
    <div class="row g-4">

        <!-- Управление на продукти -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="fas fa-box-open fa-3x text-primary"></i>
                </div>
                <h4 class="fw-bold mb-3">Продукти</h4>
                <p class="text-muted mb-4">
                    Добавяй, редактирай и изтривай продуктите в твоя онлайн магазин.
                </p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary fw-bold px-4 py-2 rounded-pill shadow-sm">
                    Управлявай
                </a>
            </div>
        </div>

        <!-- Управление на поръчки -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="fas fa-shopping-cart fa-3x text-primary"></i>
                </div>
                <h4 class="fw-bold mb-3">Поръчки</h4>
                <p class="text-muted mb-4">
                    Преглеждай и обработвай направените поръчки от клиентите.
                </p>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-primary fw-bold px-4 py-2 rounded-pill shadow-sm">
                     Управлявай
                </a>
            </div>
        </div>

        <!-- Управление на потребители -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 text-center p-4">
                <div class="mb-3">
                    <i class="fas fa-users fa-3x text-primary"></i>
                </div>
                <h4 class="fw-bold mb-3">Потребители</h4>
                <p class="text-muted mb-4">
                    Управлявай акаунтите на потребителите и техните данни.
                </p>
                <a asp-controller="Users" asp-action="Index" class="btn btn-outline-primary fw-bold px-4 py-2 rounded-pill shadow-sm">
                    Управлявай
                </a>
            </div>
        </div>
        
        <!-- 📊 Анализи и Инсайти -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 text-center p-4 border-warning shadow-sm" style="border-width:2px;">
                <div class="mb-3">
                    <i class="fas fa-chart-line fa-3x text-warning"></i>
                </div>
                <h4 class="fw-bold mb-3">Анализи</h4>
                <p class="text-muted mb-4">
                    Виж смар инсайти за продажбите и клиентите си.
                </p>
                <a asp-controller="Admin" asp-action="Insights" class="btn btn-warning text-dark fw-bold px-4 py-2 rounded-pill shadow-lg">
                    Към Анализи
                </a>
            </div>
        </div>
        
        <!-- 🎯 Goal Mapping -->
        <div class="col-lg-3 col-md-6">
            <div class="card h-100 text-center p-4 border-success shadow-sm" style="border-width:2px;">
                <div class="mb-3">
                    <i class="fas fa-bullseye fa-3x text-success"></i>
                </div>
                <h4 class="fw-bold mb-3">Goal Mapping</h4>
                <p class="text-muted mb-4">
                    Управ лявай продуктовите препоръки за всяка цел.
                </p>
                <a asp-controller="Admin" asp-action="GoalMapping" class="btn btn-success text-white fw-bold px-4 py-2 rounded-pill shadow-lg">
                    Към Mapping
                </a>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light fw-bold px-4 py-2 rounded-pill">
            ← Назад към началото
        </a>
    </div>
</div>