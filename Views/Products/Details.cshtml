@using Microsoft.AspNetCore.Http
@model GymPower.Models.Product
@{
    ViewData["Title"] = "Детайли за продукта";
}

@functions {
    // Helper function to map Bulgarian color names to CSS color codes
    string GetColorCode(string colorName)
    {
        return colorName?.ToLower() switch
        {
            "черен" => "#000000",
            "бял" => "#FFFFFF",
            "сив" => "#808080",
            "въглено сив" => "#36454F",
            "син" => "#0000FF",
            "тъмносин" => "#00008B",
            "червен" => "#FF0000",
            "оранжев" => "#FFA500",
            "корал" => "#FF7F50",
            "розов" => "#FFC0CB",
            "лилав" => "#9370DB",
            "люляк" => "#C8A2C8",
            _ => "#CCCCCC" // Default gray for unknown colors
        };
    }
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center align-items-start g-5">

            <!-- 🖼️ Product Image / Gallery -->
            <div class="col-lg-6 col-md-6">
                <!-- Main Image -->
                <div class="card border-0 overflow-hidden shadow-sm mb-3">
                    <img id="mainImage" src="@Model.ImageUrl"
                         alt="@Model.Name"
                         class="img-fluid w-100"
                         style="object-fit: cover; height: 500px; transition: opacity 0.3s ease-in-out;">
                </div>
                
                <!-- Thumbnails -->
                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="d-flex gap-2 overflow-auto pb-2">
                        <!-- Main Image Thumbnail -->
                        <div class="cursor-pointer border border-2 border-warning rounded overflow-hidden" 
                             style="width: 80px; height: 80px; min-width: 80px;"
                             onclick="changeImage('@Model.ImageUrl', this)">
                            <img src="@Model.ImageUrl" class="w-100 h-100" style="object-fit: cover;">
                        </div>

                        <!-- Extra Images -->
                        @foreach (var img in Model.Images)
                        {
                            <div class="cursor-pointer border border-secondary rounded overflow-hidden opacity-75" 
                                 style="width: 80px; height: 80px; min-width: 80px;"
                                 onmouseover="this.classList.remove('opacity-75'); this.classList.add('border-warning');"
                                 onmouseout="if(!this.classList.contains('active-thumb')) { this.classList.add('opacity-75'); this.classList.remove('border-warning'); }"
                                 onclick="changeImage('@img.ImageUrl', this)">
                                <img src="@img.ImageUrl" class="w-100 h-100" style="object-fit: cover;">
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- 🧾 Product Info -->
            <div class="col-lg-6 col-md-6">
                <h1 class="fw-bold text-primary mb-3">@Model.Name</h1>

                <span class="badge bg-secondary mb-3 fs-6">@Model.Category</span>

                <!-- Short Description -->
                <p class="lead mb-4 text-muted" style="line-height:1.7;">
                    @Model.Description
                </p>

                <!-- 📖 Long Description Section -->
                @if (!string.IsNullOrEmpty(Model.LongDescription))
                {
                    <div class="mb-4 p-3 bg-card rounded border border-light-subtle">
                        <h5 class="fw-bold text-warning mb-2">📜 Детайлно описание:</h5>
                        <p class="text-secondary small mb-0" style="white-space: pre-line; line-height: 1.6;">
                            @Model.LongDescription
                        </p>
                    </div>
                }

                <!-- Benefits Legacy Section (Optional, keep if needed or merge) -->
                @if (string.IsNullOrEmpty(Model.LongDescription)) 
                {
                     <div class="mb-4">
                        <h5 class="fw-semibold mb-2">Ползи от продукта:</h5>
                        <ul class="text-muted" style="line-height:1.7;">
                            <li>Подпомага мускулния растеж и възстановяването.</li>
                        </ul>
                    </div>
                }

                <h3 class="fw-bold text-price mb-4">
                    Цена: @GymPower.Helpers.CurrencyHelper.ToEuro(Model.Price)
                </h3>

                <div class="mb-4">
                    <i class="fas fa-box me-2"></i>
                    @if (Model.StockQuantity > 0)
                    {
                        <span class="text-success fw-semibold">В наличност (@Model.StockQuantity бр.)</span>
                    }
                    else
                    {
                        <span class="text-danger fw-semibold">Изчерпан</span>
                    }
                </div>

                <!-- 🎨 Variant Selector (if product has variants) -->
                @if (Model.Variants != null && Model.Variants.Any())
                {
                    <div class="mb-4">
                        <h5 class="fw-semibold mb-3">
                            @(Model.Variants.First().VariantType == "Цвят" ? "🎨 Избери цвят:" : "🍫 Избери вкус:")
                        </h5>
                        
                        <div id="variantSelector" class="d-flex flex-wrap gap-2">
                            @if (Model.Variants.First().VariantType == "Цвят")
                            {
                                <!-- Color swatches -->
                                @foreach (var variant in Model.Variants.Where(v => v.IsAvailable))
                                {
                                    <div class="variant-option color-swatch position-relative" 
                                         data-variant-id="@variant.Id" 
                                         data-variant-name="@variant.VariantValue"
                                         data-stock="@variant.StockQuantity"
                                         onclick="selectVariant(@variant.Id, '@variant.VariantValue', @variant.StockQuantity)"
                                         title="@variant.VariantValue (@variant.StockQuantity бр.)">
                                        <div class="color-box rounded-2 border border-2" 
                                             style="width: 50px; height: 50px; background-color: @GetColorCode(variant.VariantValue); cursor: pointer;">
                                        </div>
                                        <small class="d-block text-center mt-1" style="font-size: 0.7rem;">@variant.VariantValue</small>
                                        @if (variant.StockQuantity <= 0)
                                        {
                                            <span class="badge bg-danger position-absolute top-0 end-0" style="font-size: 0.6rem;">Изчерпан</span>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <!-- Taste pills -->
                                @foreach (var variant in Model.Variants.Where(v => v.IsAvailable))
                                {
                                    <button type="button" 
                                            class="btn btn-outline-secondary variant-option taste-pill" 
                                            data-variant-id="@variant.Id" 
                                            data-variant-name="@variant.VariantValue"
                                            data-stock="@variant.StockQuantity"
                                            onclick="selectVariant(@variant.Id, '@variant.VariantValue', @variant.StockQuantity)"
                                            @(variant.StockQuantity <= 0 ? "disabled" : "")>
                                        @variant.VariantValue
                                        @if (variant.StockQuantity <= 5 && variant.StockQuantity > 0)
                                        {
                                            <small class="text-warning">(Остават @variant.StockQuantity)</small>
                                        }
                                        else if (variant.StockQuantity <= 0)
                                        {
                                            <small class="text-danger">(Изчерпан)</small>
                                        }
                                    </button>
                                }
                            }
                        </div>
                        <small id="variantError" class="text-danger d-none mt-2">⚠️ Моля, изберете @(Model.Variants.First().VariantType.ToLower())!</small>
                    </div>
                }

                <!-- Quantity + Add to Cart -->
                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex align-items-center gap-3" id="addToCartForm">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="variantId" id="selectedVariantId" value="" />

                    <div class="d-flex align-items-center bg-card rounded-3 px-3 py-2 border">
                        <label for="quantity" class="me-2 fw-semibold">Количество:</label>
                        <input type="number" id="quantity" name="quantity" value="1" min="1" max="@Model.StockQuantity"
                               class="form-control text-center border-0 shadow-none" style="width:80px; background: transparent; color: inherit;">
                    </div>

                    <button type="submit" class="btn btn-warning fw-bold px-4 py-2 shadow-sm">
                        🛒 Добави в количката
                    </button>
                </form>

                <div class="d-flex gap-2 mt-4">
                    <a asp-controller="Products" asp-action="Index"
                       class="btn btn-outline-primary px-4 py-2 rounded-3">
                        ← Назад към продуктите
                    </a>
                    
                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning fw-bold px-4 py-2 rounded-3 shadow-sm">
                            <i class="fas fa-edit me-2"></i> Редактирай
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- 🧩 Related Products -->
        <div class="mt-5 pt-4 border-top">
            <h3 class="text-center fw-bold mb-4">Подобни продукти</h3>
            <div class="row g-4 justify-content-center">
                @foreach (var related in ViewBag.RelatedProducts as IEnumerable<GymPower.Models.Product> ?? Enumerable.Empty<GymPower.Models.Product>())
                {
                    <div class="col-md-4 col-lg-3">
                        <div class="card h-100 shadow-sm text-center border-0">
                            <img src="@related.ImageUrl" class="card-img-top" alt="@related.Name"
                                 style="height:200px; object-fit:cover;">
                            <div class="card-body">
                                <h6 class="fw-bold card-title">@related.Name</h6>
                                <p class="text-price fw-bold">@GymPower.Helpers.CurrencyHelper.ToEuro(related.Price)</p>
                                <a asp-action="Details" asp-route-id="@related.Id"
                                   class="btn btn-outline-primary btn-sm">Виж продукта</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- 🔁 Smart Recommendations -->
        @if (ViewBag.RecommendedProducts != null && ((IEnumerable<GymPower.Models.Product>)ViewBag.RecommendedProducts).Any())
        {
            <div class="mt-5 pt-4 border-top">
                <h3 class="text-center fw-bold mb-4 text-warning">🔁 Препоръчано за теб</h3>
                <div class="row g-4 justify-content-center">
                    @foreach (var rec in ViewBag.RecommendedProducts as IEnumerable<GymPower.Models.Product>)
                    {
                        <div class="col-md-4 col-lg-3">
                            <div class="card h-100 shadow-lg text-center border-warning">
                                <div class="position-relative">
                                    <img src="@rec.ImageUrl" class="card-img-top" alt="@rec.Name"
                                         style="height:200px; object-fit:cover;">
                                    <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">💡 Топ избор</span>
                                </div>
                                <div class="card-body">
                                    <h6 class="fw-bold card-title">@rec.Name</h6>
                                    <p class="text-price fw-bold">@GymPower.Helpers.CurrencyHelper.ToEuro(rec.Price)</p>
                                    <a asp-action="Details" asp-route-id="@rec.Id"
                                       class="btn btn-primary text-white btn-sm shadow-sm">Виж детайли</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="toastMessage"
             class="position-fixed bottom-0 end-0 mb-4 me-4 bg-success text-white fw-semibold px-4 py-3 rounded-3 shadow-lg"
             style="z-index: 9999; animation: fadeIn 0.4s;">
            ✅ @TempData["SuccessMessage"]
        </div>

        <script>
            setTimeout(() => {
                const toast = document.getElementById("toastMessage");
                if (toast) toast.remove();
            }, 2500);
        </script>
    }
</section>

<script>
    function changeImage(src, thumbnail) {
        // Change Main Image
        const mainImg = document.getElementById('mainImage');
        mainImg.style.opacity = 0;
        setTimeout(() => {
            mainImg.src = src;
            mainImg.style.opacity = 1;
        }, 150);

        // Update Active State
        document.querySelectorAll('.cursor-pointer').forEach(el => {
            el.classList.remove('border-warning', 'active-thumb');
            el.classList.add('border-secondary', 'opacity-75');
        });

        thumbnail.classList.remove('border-secondary', 'opacity-75');
        thumbnail.classList.add('border-warning', 'active-thumb');
    }

    // ✅ Variant Selection Logic
    let selectedVariant = null;

    function selectVariant(variantId, variantName, stock) {
        if (stock <= 0) return; // Don't allow selection of out-of-stock variants

        selectedVariant = variantId;
        document.getElementById('selectedVariantId').value = variantId;
        document.getElementById('variantError').classList.add('d-none');

        // Update visual selection for color swatches
        document.querySelectorAll('.variant-option').forEach(el => {
            el.classList.remove('selected');
            const colorBox = el.querySelector('.color-box');
            if (colorBox) {
                colorBox.classList.remove('border-warning', 'border-3');
                colorBox.classList.add('border-2');
            }
        });

        const selected = document.querySelector(`[data-variant-id="${variantId}"]`);
        selected.classList.add('selected');
        
        const selectedColorBox = selected.querySelector('.color-box');
        if (selectedColorBox) {
            selectedColorBox.classList.remove('border-2');
            selectedColorBox.classList.add('border-warning', 'border-3');
        }

        // Update visual selection for taste pills
        document.querySelectorAll('.taste-pill').forEach(btn => {
            btn.classList.remove('btn-warning', 'fw-bold');
            btn.classList.add('btn-outline-secondary');
        });
        
        if (selected.classList.contains('taste-pill')) {
            selected.classList.remove('btn-outline-secondary');
            selected.classList.add('btn-warning', 'fw-bold');
        }

        // Update max quantity based on variant stock
        const quantityInput = document.getElementById('quantity');
        if (quantityInput) {
            quantityInput.max = stock;
            if (parseInt(quantityInput.value) > stock) {
                quantityInput.value = stock;
            }
        }
    }

    // Form validation
    document.getElementById('addToCartForm')?.addEventListener('submit', function(e) {
        const hasVariants = document.getElementById('variantSelector');
        if (hasVariants && !selectedVariant) {
            e.preventDefault();
            document.getElementById('variantError').classList.remove('d-none');
            document.getElementById('variantSelector').scrollIntoView({ behavior: 'smooth', block: 'center' });
            return false;
        }
    });
</script>

<style>
    .variant-option {
        transition: all 0.2s ease;
    }
    
    .color-swatch:hover .color-box {
        transform: scale(1.1);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }
    
    .taste-pill {
        border-radius: 20px;
        padding: 8px 16px;
        transition: all 0.2s ease;
    }
    
    .taste-pill:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.15);
    }
</style>