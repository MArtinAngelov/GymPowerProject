@using Microsoft.AspNetCore.Http
@model IEnumerable<GymPower.Models.Product>
@{
    ViewData["Title"] = "Премиум добавки - GymPower";
}
<!-- 🛒 Product Page Hero Slider -->
<div id="productsCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="2200">
    <div class="carousel-inner">

        <!-- Slide 1 -->
        <div class="carousel-item active" style="background-image: url('/images/hero/ManWithSuplements.png');">
            <div class="overlay"></div>
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center">
                <h1 class="fw-bold display-5 mb-2">💪 Избери своята цел</h1>
                <p class="lead mb-3">Открий добавките, които ще те доближат до нея.</p>
                <a href="/Products?category=Изграждане на мускулна маса" class="btn btn-warning btn-sm px-4 fw-bold">ИЗГРАЖДАНЕ НА МУСКУЛНА МАСА</a>
            </div>
        </div>

        <!-- Slide 2 -->
        <div class="carousel-item" style="background-image: url('/images/hero/FatBurner.png');">
            <div class="overlay"></div>
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center">
                <h1 class="fw-bold display-5 mb-2">🔥 Изгори мазнините интелигентно</h1>
                <p class="lead mb-3">Fat Burners и L-Carnitine формули за по-добри резултати.</p>
                <a href="/Products?category=Отслабване" class="btn btn-warning btn-sm px-4 fw-bold">ОТСЛАБВАНЕ</a>
            </div>
        </div>

        <!-- Slide 3 -->
        <div class="carousel-item" style="background-image: url('/images/hero/ThorPreWorkout.png');">
            <div class="overlay"></div>
            <div class="carousel-caption d-flex flex-column justify-content-center align-items-center">
                <h1 class="fw-bold display-5 mb-2">⚡ Повиши издръжливостта си</h1>
                <p class="lead mb-3">Открий Energy и Pump формули за максимална производителност.</p>
                <a href="/Products?category=Висока производителност" class="btn btn-warning btn-sm px-4 fw-bold">ВИСОКА ПРОИЗВОДИТЕЛНОСТ</a>
            </div>
        </div>
    </div>
</div>

<!-- 🎨 Carousel Styles -->
<style>
    #productsCarousel {
        height: 50vh;
        position: relative;
        overflow: hidden;
    }

    .carousel-item {
        height: 50vh;
        background-size: cover;
        background-position: center;
        transition: opacity 0.8s ease-in-out, transform 3s ease;
    }

        .carousel-item.active {
            animation: zoomIn 4s ease-in-out infinite alternate;
        }

    @@keyframes zoomIn {
        from {
            transform: scale(1);
        }

        to {
            transform: scale(1.05);
        }
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.55);
        z-index: 1;
    }

    .carousel-caption {
        z-index: 10;
        text-align: center;
        color: #fff;
        text-shadow: 0 2px 12px rgba(0,0,0,0.9);
    }

        .carousel-caption h1 {
            font-size: 2rem;
            background: linear-gradient(90deg, #ff6b35, #f7b733);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: glow 4s ease-in-out infinite alternate;
        }

    @@keyframes glow {
        from {
            text-shadow: 0 0 10px rgba(255,107,53,0.4);
        }

        to {
            text-shadow: 0 0 25px rgba(255,193,7,0.9);
        }
    }

    .carousel-caption p {
        font-size: 1rem;
        color: #f1f1f1;
        margin-bottom: 10px;
    }

    .carousel-caption .btn {
        border-radius: 40px;
        padding: 8px 25px;
        font-size: 1rem;
        font-weight: 700;
        box-shadow: 0 0 15px rgba(255, 107, 53, 0.4);
        transition: all 0.3s ease;
    }

        .carousel-caption .btn:hover {
            transform: scale(1.1);
            box-shadow: 0 0 25px rgba(255, 193, 7, 0.7);
        }
</style>

<div class="container mt-5">
    <!-- Категории -->
    <div class="row mb-5">
        <div class="col-12">
            <h3 class="text-center mb-4 fw-bold">ПАЗАРУВАЙ ПО КАТЕГОРИЯ</h3>
            <div class="d-flex flex-wrap gap-2 justify-content-center">
                <a href="@Url.Action("Index", new { category = "" })"
                   class="btn @(string.IsNullOrEmpty(ViewContext.HttpContext.Request.Query["category"]) ? "btn-warning text-dark fw-semibold" : "btn-outline-secondary")">
                    <i class="fas fa-th-large me-2"></i> Всички продукти
                </a>

                <a href="@Url.Action("Index", new { category = "Изграждане на мускулна маса" })"
                   class="btn @(ViewContext.HttpContext.Request.Query["category"] == "Изграждане на мускулна маса" ? "btn-warning text-dark fw-semibold" : "btn-outline-secondary")">
                    💪 Изграждане на мускулна маса
                </a>

                <a href="@Url.Action("Index", new { category = "Отслабване" })"
                   class="btn @(ViewContext.HttpContext.Request.Query["category"] == "Отслабване" ? "btn-warning text-dark fw-semibold" : "btn-outline-secondary")">
                    🔥 Отслабване
                </a>

                <a href="@Url.Action("Index", new { category = "Регенерация" })"
                   class="btn @(ViewContext.HttpContext.Request.Query["category"] == "Регенерация" ? "btn-warning text-dark fw-semibold" : "btn-outline-secondary")">
                    ♻️ Регенерация
                </a>

                <a href="@Url.Action("Index", new { category = "Висока производителност" })"
                   class="btn @(ViewContext.HttpContext.Request.Query["category"] == "Висока производителност" ? "btn-warning text-dark fw-semibold" : "btn-outline-secondary")">
                    ⚡ Висока производителност
                </a>

                <a href="@Url.Action("Index", new { category = "Имунитет" })"
                   class="btn @(ViewContext.HttpContext.Request.Query["category"] == "Имунитет" ? "btn-warning text-dark fw-semibold" : "btn-outline-secondary")">
                    💊 Имунитет
                </a>

                <a href="@Url.Action("Index", new { category = "Здравословна закуска" })"
                   class="btn @(ViewContext.HttpContext.Request.Query["category"] == "Здравословна закуска" ? "btn-warning text-dark fw-semibold" : "btn-outline-secondary")">
                    🍎 Здравословна закуска
                </a>

                <a href="@Url.Action("Index", new { category = "Облекло" })"
                   class="btn @(ViewContext.HttpContext.Request.Query["category"] == "Облекло" ? "btn-warning text-dark fw-semibold" : "btn-outline-secondary")">
                    👕 Облекло
                </a>
            </div>
        </div>
    </div>

    <!-- Бутон за админ -->
    @if (Context.Session.GetString("Role") == "Admin")
    {
        <div class="row mb-4">
            <div class="col-12 text-end">
                <a asp-action="Create" class="btn btn-success btn-lg fw-bold">
                    <i class="fas fa-plus-circle me-2"></i> Добави нов продукт
                </a>
            </div>
        </div>
    }

    <!-- Продукти -->
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                <div class="card product-card h-100 border-0 shadow-sm" 
                     style="cursor: pointer;"
                     onclick="if(!event.target.closest('a, button')) location.href='@Url.Action("Details", "Products", new { id = product.Id })'">
                    <!-- Снимка -->
                    <div class="position-relative overflow-hidden">
                        <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name"
                             onerror="this.src='/images/products/default-product.jpg'"
                             style="height: 250px; object-fit: cover;">

                        <span class="badge position-absolute top-0 start-0 m-3 bg-warning text-dark fw-bold">
                            <i class="fas fa-crown me-1"></i> Премиум
                        </span>

                        <!-- Наличност -->
                        @if (product.StockQuantity < 10)
                        {
                            <span class="badge bg-danger position-absolute top-0 end-0 m-3">
                                <i class="fas fa-exclamation-triangle me-1"></i> Ограничени количества
                            </span>
                        }
                    </div>

                    <!-- Детайли -->
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate fw-bold">@product.Name</h5>
                        <div class="mb-2">
                            <span class="badge bg-secondary">@product.Category</span>
                        </div>

                        <p class="card-text text-truncate flex-grow-1 text-muted">@product.Description</p>

                        <!-- Цена и бутони -->
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-price fw-bold fs-5">@GymPower.Helpers.CurrencyHelper.ToEuro(product.Price)</span>
                                <div class="text-warning">
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star"></i>
                                    <i class="fas fa-star-half-alt"></i>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary flex-fill">
                                    <i class="fas fa-eye"></i> Детайли
                                </a>

                                @if (Context.Session.GetString("Role") == "Admin")
                                {
                                    <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-warning text-dark fw-bold" 
                                       onclick="event.stopPropagation()">
                                        <i class="fas fa-edit me-1"></i> Редактирай
                                    </a>
                                }
                                else if (product.StockQuantity > 0)
                                {
                                    <a class="btn btn-primary flex-fill add-to-cart-link shadow-sm"
                                       asp-controller="Cart"
                                       asp-action="AddToCart"
                                       asp-route-id="@product.Id">
                                        <i class="fas fa-cart-plus me-1"></i> Купи
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary flex-fill" disabled>Изчерпано</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <h3>Няма намерени продукти</h3>
            <p class="text-muted">Няма налични продукти в тази категория в момента.</p>
            <a href="@Url.Action("Index", new { category = "" })" class="btn btn-warning text-dark fw-bold">
                <i class="fas fa-th-large me-2"></i> Виж всички продукти
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("click", async (e) => {
            const link = e.target.closest(".add-to-cart-link");
            if (!link) return;

            e.preventDefault();
            const url = link.getAttribute("href");

            try {
                const response = await fetch(url + "?t=" + new Date().getTime(), { // Prevent cache
                    method: "GET",
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                if (response.ok) {
                    showToast("✅ Продуктът е добавен в количката!");
                    if(typeof updateCartCount === 'function') {
                        updateCartCount();
                    }
                } else {
                    showToast("⚠️ Неуспешно добавяне на продукта.", true);
                }
            } catch {
                showToast("⚠️ Грешка от сървъра. Опитайте отново по-късно.", true);
            }
        });

        function showToast(message, isError = false) {
            const toast = document.createElement("div");
            toast.textContent = message;
            Object.assign(toast.style, {
                position: "fixed",
                bottom: "30px",
                right: "30px",
                background: isError ? "#dc3545" : "#28a745",
                color: "#fff",
                padding: "12px 20px",
                borderRadius: "8px",
                boxShadow: "0 2px 10px rgba(0,0,0,0.2)",
                zIndex: "9999",
                fontWeight: "600",
                transition: "opacity 0.3s ease"
            });
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = "0";
                setTimeout(() => toast.remove(), 500);
            }, 2000);
        }
    </script>
}