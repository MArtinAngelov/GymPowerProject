@model GymPower.Models.User
@{
    ViewData["Title"] = "Моят профил";
}

<style>
    .premium-profile-card {
        background: rgba(30, 31, 41, 0.7);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        overflow: hidden;
    }
    
    .profile-header-gradient {
        background: linear-gradient(135deg, #FFB800 0%, #FF8A00 100%);
        padding: 2.5rem 2rem 4rem 2rem;
        position: relative;
    }
    
    .profile-avatar-container {
        width: 120px;
        height: 120px;
        background: #111;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        font-weight: 800;
        color: #FFB800;
        border: 5px solid #0b0b14;
        box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        margin: -60px auto 20px;
        position: relative;
        z-index: 2;
    }

    .profile-stat-box {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 15px;
        padding: 1.5rem 1rem;
        transition: transform 0.3s ease, background 0.3s ease;
    }

    .profile-stat-box:hover {
        transform: translateY(-5px);
        background: rgba(255, 184, 0, 0.05);
        border-color: rgba(255, 184, 0, 0.2);
    }

    .stat-icon {
        font-size: 1.8rem;
        color: #FFB800;
        margin-bottom: 10px;
    }

    .stat-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: rgba(255,255,255,0.5);
        letter-spacing: 1px;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #fff;
    }

    .btn-premium-action {
        border-radius: 12px;
        padding: 14px 20px;
        font-weight: 700;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }
    
    .btn-generate {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: #fff;
        border: none;
        box-shadow: 0 5px 15px rgba(0, 242, 254, 0.3);
    }
    
    .btn-generate:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 242, 254, 0.5);
        color: #fff;
    }

    .btn-edit {
        background: linear-gradient(135deg, #FFB800 0%, #FF8A00 100%);
        color: #000;
        border: none;
        box-shadow: 0 5px 15px rgba(255, 184, 0, 0.3);
    }
    
    .btn-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255, 184, 0, 0.5);
        color: #000;
    }

    .btn-logout {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .btn-logout:hover {
        background: rgba(255, 59, 48, 0.1);
        color: #ff3b30;
        border-color: rgba(255, 59, 48, 0.3);
    }
</style>

<section class="py-5" style="min-height: calc(100vh - 80px);">
    <div class="container animate-fade-in">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-8">
                <div class="premium-profile-card">
                    <!-- Header -->
                    <div class="profile-header-gradient text-center">
                        <h2 class="text-dark fw-bold mb-1" style="font-size: 2.2rem;" data-bg="Команден център" data-en="Command Center">Команден Център</h2>
                        <p class="text-dark opacity-75 fw-semibold mb-0" data-bg="Управлявай своя акаунт и фитнес цели" data-en="Manage your account & fitness goals">Управлявай своя акаунт и фитнес цели</p>
                    </div>

                    <!-- Avatar -->
                    <div class="profile-avatar-container">
                        @Model.Username.Substring(0, 1).ToUpper()
                    </div>

                    <div class="px-4 pb-5 px-md-5">
                        
                        <div class="text-center mb-5">
                            <h3 class="fw-bold text-white mb-1">@Model.Username</h3>
                            <p class="text-muted mb-0"><i class="fas fa-envelope me-2"></i>@Model.Email</p>
                        </div>

                        <!-- Stats Row -->
                        <div class="row g-3 mb-5">
                            <div class="col-sm-4">
                                <div class="profile-stat-box text-center h-100">
                                    <i class="fas fa-bullseye stat-icon text-info"></i>
                                    <div class="stat-label" data-bg="Фитнес Цел" data-en="Fitness Goal">Фитнес Цел</div>
                                    <div class="stat-value">
                                        @if(Model.FitnessGoal == "MuscleGain")
                                        {
                                            <span data-bg="Покачване на маса" data-en="Muscle Gain">Покачване на маса</span>
                                        }
                                        else if(Model.FitnessGoal == "FatLoss")
                                        {
                                            <span data-bg="Изгаряне на мазнини" data-en="Fat Loss">Изгаряне на мазнини</span>
                                        }
                                        else
                                        {
                                            <span data-bg="Поддържане" data-en="Maintenance">Поддържане</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="profile-stat-box text-center h-100">
                                    <i class="fas fa-dumbbell stat-icon text-success"></i>
                                    <div class="stat-label" data-bg="Ниво" data-en="Experience Level">Ниво</div>
                                    <div class="stat-value">
                                        @if(Model.TrainingLevel == "Advanced")
                                        {
                                            <span data-bg="Професионалист" data-en="Advanced">Професионалист</span>
                                        }
                                        else if(Model.TrainingLevel == "Intermediate")
                                        {
                                            <span data-bg="Напреднал" data-en="Intermediate">Напреднал</span>
                                        }
                                        else
                                        {
                                            <span data-bg="Начинаещ" data-en="Beginner">Начинаещ</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4">
                                <div class="profile-stat-box text-center h-100">
                                    <i class="fas fa-calendar-alt stat-icon text-warning"></i>
                                    <div class="stat-label" data-bg="Регистрация" data-en="Member Since">Регистрация</div>
                                    <div class="stat-value">@Model.CreatedAt.ToString("MMM yyyy")</div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="d-flex flex-column gap-3 max-w-md mx-auto" style="max-width: 400px;">
                            <form asp-controller="Planner" asp-action="Generate" method="post" class="w-100">
                                <button type="submit" class="btn btn-premium-action btn-generate w-100">
                                    <i class="fas fa-bolt"></i>
                                    <span data-bg="Генерирай Персонален План" data-en="Generate Custom Plan">Генерирай Персонален План</span>
                                </button>
                            </form>

                            <a asp-action="EditProfile" class="btn btn-premium-action btn-edit">
                                <i class="fas fa-user-edit"></i>
                                <span data-bg="Редактирай Профила" data-en="Edit Profile">Редактирай Профила</span>
                            </a>

                            <a asp-action="Logout" class="btn btn-premium-action btn-logout">
                                <i class="fas fa-sign-out-alt"></i>
                                <span data-bg="Изход от акаунта" data-en="Sign Out">Изход от акаунта</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
