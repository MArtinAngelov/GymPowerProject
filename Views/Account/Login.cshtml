@{
    ViewData["Title"] = "Вход";
}

<div class="auth-page-wrapper">
    <!-- Background Sides -->
    <div class="auth-bg-side auth-bg-left"></div>
    <div class="auth-bg-side auth-bg-right"></div>

    <div class="auth-card-container">
        <div class="auth-glass-card text-center">
            <div class="mb-4">
                <h2 class="fw-bold text-uppercase" style="letter-spacing: 3px; font-size: 2.2rem;">
                    <i class="fas fa-dumbbell text-warning me-2"></i> GymPower
                </h2>
                <div class="h5 text-white-50 mt-2 fw-light">Влез в профила си</div>
            </div>

            <!-- Error Messages -->
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 rounded-pill py-2 shadow-sm mb-4" role="alert" style="background: rgba(220, 53, 69, 0.2); color: #ff8e98;">
                    <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
                </div>
            }

            <form method="post" class="mt-4">
                <div class="form-floating mb-3 auth-floating-label">
                    <input type="text" name="username" class="form-control" id="floatingInput" placeholder="Потребителско име" required>
                    <label for="floatingInput">👤 Потребителско име</label>
                </div>

                <div class="form-floating mb-4 auth-floating-label">
                    <input type="password" name="password" class="form-control" id="floatingPassword" placeholder="Парола" required>
                    <label for="floatingPassword">🔒 Парола</label>
                </div>

                <button type="submit" class="btn btn-auth btn-lg w-100 mt-2">
                    Влез <i class="fas fa-arrow-right ms-2 small"></i>
                </button>
            </form>

            <div class="mt-4 pt-4 border-top border-secondary border-opacity-25">
                <p class="text-white-50 mb-2">Нямаш акаунт?</p>
                <a asp-action="Register" class="text-warning fw-bold text-decoration-none h6">
                    Създай нов профил <i class="fas fa-plus-circle ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    /* Prevent default layout padding if any */
    body { padding-top: 0 !important; }
    main.container { max-width: 100% !important; padding: 0 !important; }
</style>

<style>
    .form-control:focus {
        background: #1a1a2e;
        color: white;
        border-color: var(--primary);
        box-shadow: 0 0 10px rgba(255, 107, 53, 0.3);
    }
    button:hover {
        transform: scale(1.02);
        box-shadow: 0 5px 15px rgba(255, 107, 53, 0.4);
    }
</style>