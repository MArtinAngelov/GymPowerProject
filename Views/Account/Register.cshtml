@model GymPower.Models.User

@{
    ViewData["Title"] = "Регистрация";
}

<div class="auth-page-wrapper">
    <!-- Background Sides -->
    <div class="auth-bg-side auth-bg-left"></div>
    <div class="auth-bg-side auth-bg-right"></div>

    <div class="auth-card-container" style="max-width: 600px;">
        <div class="auth-glass-card">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-uppercase" style="letter-spacing: 3px; font-size: 2.2rem;">
                    <i class="fas fa-user-plus text-warning me-2"></i> Нов Профил
                </h2>
                <div class="h5 text-white-50 mt-2 fw-light">Присъедини се към GymPower</div>
            </div>

            <form asp-action="Register" class="row g-3">
                <div class="col-md-12">
                    <div class="form-floating auth-floating-label">
                        <input asp-for="Username" class="form-control" id="regUsername" placeholder="Потребителско име" required />
                        <label for="regUsername">👤 Потребителско име</label>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-floating auth-floating-label">
                        <input asp-for="Email" class="form-control" id="regEmail" placeholder="Имейл" required />
                        <label for="regEmail">📧 Имейл</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating auth-floating-label">
                        <input asp-for="Password" type="password" class="form-control" id="regPass" placeholder="Парола" required />
                        <label for="regPass">🔒 Парола</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-floating auth-floating-label">
                        <input type="password" class="form-control" id="regConfirmPass" name="ConfirmPassword" placeholder="Потвърди парола" required />
                        <label for="regConfirmPass">🔒 Потвърди парола</label>
                        <span id="confirmPasswordError" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-floating auth-floating-label">
                        <select asp-for="FitnessGoal" class="form-select" id="regGoal">
                            <option value="MassGain">💪 Покачване на мускулна маса</option>
                            <option value="WeightLoss">🥗 Отслабване</option>
                            <option value="Maintenance">⚖️ Поддържане</option>
                        </select>
                        <label for="regGoal">🎯 Фитнес цел</label>
                        <span asp-validation-for="FitnessGoal" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-auth btn-lg w-100">
                        Регистрирай се <i class="fas fa-check-circle ms-2 small"></i>
                    </button>
                </div>
            </form>

            <div class="mt-4 pt-4 border-top border-secondary border-opacity-25 text-center">
                <p class="text-white-50 mb-2">Вече имаш акаунт?</p>
                <a asp-action="Login" class="text-warning fw-bold text-decoration-none h6">
                    Влез в профила си <i class="fas fa-sign-in-alt ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    /* Prevent default layout padding if any */
    body { padding-top: 0 !important; }
    main.container { max-width: 100% !important; padding: 0 !important; }
</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const usernameInput = document.getElementById("regUsername");
            const emailInput = document.getElementById("regEmail");
            const passwordInput = document.getElementById("regPass");
            const confirmPasswordInput = document.getElementById("regConfirmPass");
            const confirmPasswordError = document.getElementById("confirmPasswordError");
            const submitButton = document.querySelector("button[type='submit']");

            async function validateField(field, type) {
                const value = field.value;
                if (value.length < 3) return;

                const payload = {};
                payload[type] = value;

                try {
                    const response = await fetch('/api/validation/check-user', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const result = await response.json();
                    
                    const isValid = type === 'username' ? result.usernameAvailable : result.emailAvailable;
                    const feedbackId = type === 'username' ? 'usernameFeedback' : 'emailFeedback';
                    
                    let feedback = document.getElementById(feedbackId);
                    if (!feedback) {
                        feedback = document.createElement('div');
                        feedback.id = feedbackId;
                        feedback.style.fontSize = '0.8rem';
                        feedback.style.marginTop = '5px';
                        field.parentNode.appendChild(feedback);
                    }

                    if (isValid) {
                        field.style.borderColor = '#2ec4b6'; // Success Green
                        feedback.style.color = '#2ec4b6';
                        feedback.innerHTML = '<i class="fas fa-check-circle"></i> Свободно';
                    } else {
                        field.style.borderColor = '#ff6b35'; // Error Orange
                        feedback.style.color = '#ff6b35';
                        feedback.innerHTML = '<i class="fas fa-times-circle"></i> Заето';
                    }
                } catch (error) {
                    console.error('Validation error:', error);
                }
            }

            usernameInput.addEventListener("blur", () => validateField(usernameInput, "username"));
            emailInput.addEventListener("blur", () => validateField(emailInput, "email"));

            // Password matching validation
            function validatePasswordMatch() {
                const password = passwordInput.value;
                const confirmPassword = confirmPasswordInput.value;

                if (confirmPassword.length === 0) {
                    confirmPasswordInput.style.borderColor = '#444';
                    confirmPasswordError.textContent = '';
                    return true;
                }

                if (password === confirmPassword) {
                    confirmPasswordInput.style.borderColor = '#2ec4b6';
                    confirmPasswordError.style.color = '#2ec4b6';
                    confirmPasswordError.innerHTML = '<i class="fas fa-check-circle"></i> Паролите съвпадат';
                    return true;
                } else {
                    confirmPasswordInput.style.borderColor = '#ff6b35';
                    confirmPasswordError.style.color = '#ff6b35';
                    confirmPasswordError.innerHTML = '<i class="fas fa-times-circle"></i> Паролите не съвпадат';
                    return false;
                }
            }

            confirmPasswordInput.addEventListener("input", validatePasswordMatch);
            passwordInput.addEventListener("input", () => {
                if (confirmPasswordInput.value.length > 0) {
                    validatePasswordMatch();
                }
            });

            // Prevent form submission if passwords don't match
            document.querySelector("form").addEventListener("submit", function(e) {
                if (!validatePasswordMatch() && confirmPasswordInput.value.length > 0) {
                    e.preventDefault();
                    confirmPasswordError.innerHTML = '<i class="fas fa-times-circle"></i> Моля, уверете се, че паролите съвпадат';
                }
            });
        });
    </script>
}
