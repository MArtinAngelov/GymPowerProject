@model IEnumerable<GymPower.Models.Order>
@{
    ViewData["Title"] = "Моите поръчки";
}

<section class="py-5">
    <div class="container">
        <h2 class="fw-bold text-center mb-5 text-primary">📦 Моите поръчки</h2>

        @if (!Model.Any())
        {
            <div class="text-center text-muted">
                <p class="fs-5">Нямаш направени поръчки.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-warning rounded-pill px-4 py-2 fw-bold">
                    🛒 Разгледай продукти
                </a>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var order in Model)
                {
                    <div class="col-md-6 mb-4">
                        <div class="card border-0 shadow-sm rounded-4 h-100" style="border-left:4px solid var(--primary) !important;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="fw-bold mb-0">Поръчка №@order.Id</h5>
                                    <span class="text-muted small">@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>

                                <p class="mb-1 small">
                                    Статус:
                                    <span class="badge @(order.Status == "Доставена" ? "bg-success" : order.Status == "Отказана" ? "bg-danger" : "bg-warning text-dark")">
                                        @order.Status
                                    </span>
                                </p>
                                <p class="mb-2 fw-bold">Общо: <span class="text-price">@GymPower.Helpers.CurrencyHelper.ToEuro(order.TotalPrice)</span></p>

                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    @foreach (var item in order.OrderItems.Take(3))
                                    {
                                        <a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none">
                                            <img src="@item.Product.ImageUrl"
                                                 style="width:60px;height:60px;object-fit:cover;border-radius:10px;"
                                                 class="border shadow-sm" />
                                        </a>
                                    }
                                    @if (order.OrderItems.Count > 3)
                                    {
                                        <div class="d-flex align-items-center justify-content-center bg-light rounded-circle border"
                                             style="width:60px;height:60px;">
                                            <span class="fw-bold text-muted">+@((order.OrderItems.Count - 3))</span>
                                        </div>
                                    }
                                </div>

                                <div class="text-end">
                                    <a asp-action="Details" asp-route-id="@order.Id"
                                       class="btn btn-outline-primary rounded-pill px-4 py-2 fw-bold">
                                        👁️ Преглед
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
