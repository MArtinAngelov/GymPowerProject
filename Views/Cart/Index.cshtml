@model List<GymPower.Models.CartItem>

<div class="container my-5">
    <h2 class="mb-4 text-center fw-bold text-primary">
        <i class="fas fa-shopping-cart me-2"></i> Твоята количка
    </h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger text-center shadow-sm p-3 mb-4 rounded-3">
            <i class="fas fa-exclamation-circle me-2 fa-lg"></i> 
            <span class="fw-bold">@TempData["ErrorMessage"]</span>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning text-center shadow-sm p-4">
            Количката ти е празна.
            <a asp-controller="Products" asp-action="Index" class="btn btn-warning ms-2 fw-semibold">
                Разгледай продукти
            </a>
        </div>
    }
    else
    {
        <div class="card shadow-sm rounded-4 border-0">
            <div class="card-body p-4">
                <table class="table align-middle">
                    <thead style="background: var(--gradient-primary); color: #fff;">
                        <tr>
                            <th>Продукт</th>
                            <th>Цена</th>
                            <th>Количество</th>
                            <th>Общо</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@item.ImageUrl" alt="@item.ProductName" width="70"
                                             class="rounded me-3 shadow-sm" />
                                        <div>
                                            <span class="fw-semibold d-block">@item.ProductName</span>
                                            @if (!string.IsNullOrEmpty(item.VariantType) && !string.IsNullOrEmpty(item.VariantValue))
                                            {
                                                <small class="badge bg-secondary mt-1">
                                                    @item.VariantType: @item.VariantValue
                                                </small>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="fw-semibold">@GymPower.Helpers.CurrencyHelper.ToEuro(item.Price)</td>
                                <td>@item.Quantity</td>
                                <td class="fw-bold text-price">@GymPower.Helpers.CurrencyHelper.ToEuro(item.Price * item.Quantity)</td>
                                <td>
                                    <a asp-action="RemoveFromCart" asp-route-id="@item.ProductId"
                                       class="btn btn-outline-danger btn-sm rounded-pill fw-semibold">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="text-end mt-3">
                    <a asp-action="ClearCart" class="btn btn-outline-secondary me-2 rounded-pill">Изчисти количката</a>
                    <a asp-action="Checkout" class="btn btn-primary rounded-pill shadow-sm fw-semibold">
                        Продължи към плащане
                    </a>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mt-4">
            <div class="card shadow-sm border-0" style="width: 320px;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Обобщение на поръчката</h5>
                    <hr />
                    <p class="mb-2">
                        Междинна сума:
                        <span class="float-end fw-semibold">
                            @GymPower.Helpers.CurrencyHelper.ToEuro(Model.Sum(x => x.Price * x.Quantity))
                        </span>
                    </p>
                    <p class="mb-2">
                        Доставка:
                        <span class="float-end text-success">Безплатна</span>
                    </p>
                    <hr />
                    <h5>
                        Общо:
                        <span class="float-end text-price fw-bold">
                            @GymPower.Helpers.CurrencyHelper.ToEuro(Model.Sum(x => x.Price * x.Quantity))
                        </span>
                    </h5>
                </div>
            </div>
        </div>

        <!-- 📦 Frequently Bought Together (Sidebar/Bottom) -->
        @if (ViewBag.FreqBought != null && ((IEnumerable<GymPower.Models.Product>)ViewBag.FreqBought).Any())
        {
            <div class="mt-5 pt-4 border-top">
                <h4 class="fw-bold mb-4 text-secondary">📦 Често купувани заедно</h4>
                <div class="row g-3">
                    @foreach (var p in ViewBag.FreqBought as IEnumerable<GymPower.Models.Product>)
                    {
                        <div class="col-md-4">
                            <div class="card h-100 shadow-sm border-0 d-flex flex-row align-items-center p-2">
                                <img src="@p.ImageUrl" alt="@p.Name" class="rounded ms-2"
                                     style="width: 80px; height: 80px; object-fit: cover;">
                                <div class="card-body py-1 px-3 d-flex flex-column justify-content-center">
                                    <h6 class="fw-bold mb-1 text-truncate" style="max-width: 150px;">@p.Name</h6>
                                    <span class="text-price small fw-bold mb-2">@GymPower.Helpers.CurrencyHelper.ToEuro(p.Price)</span>
                                    <a href="@Url.Action("AddToCart", "Cart", new { id = p.Id })" 
                                       class="btn btn-outline-primary btn-sm rounded-pill fw-bold" style="font-size: 0.8rem;">
                                       + Добави
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>